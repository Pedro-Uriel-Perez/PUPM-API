generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Rol{
  ide Int @default(autoincrement())@id
  description String @db.VarChar(200)
  status Boolean
  users User[]
}

model User {
  id         Int      @id @default(autoincrement())
  name       String
  lastname   String
  username   String   @unique
  password     String
  refreshToken String?
  created_at   DateTime @default(now())
  tasks      Task[]
  rol_id Int?
  rol    Rol? @relation(fields: [rol_id], references: [ide])
}

model Task {
  id          Int    @id @default(autoincrement())
  name        String @db.VarChar(100)
  description String @db.VarChar(250)
  priority    Int
  user_id     Int
  user        User   @relation(fields: [user_id], references: [id])

  @@map("tasks")
}
